# Copy to .env and fill in values. Never commit .env.

# Cinderhaven Postgres SSOT
DATABASE_URL=postgres://user:password@host:5432/cinderhaven

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-hex-string
FLASK_DEBUG=false

# Flask-Caching (FileSystemCache — use /cache on Fly.io, local path in dev)
CACHE_DIR=/tmp/pdf-cache
